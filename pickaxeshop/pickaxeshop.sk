# --- ФУНКЦИЯ ОТРИСОВКИ ПРЕДМЕТА ---
function setSellItem(p: player, s: number, i: item, n: text):
    set {_u} to uuid of {_p}
    if {sellmode::%{_u}%} is not set:
        set {sellmode::%{_u}%} to 1
    
    set {_m} to {sellmode::%{_u}%}
    set {_id} to "%type of {_i}%"
    replace all " " with "_" in {_id}
    set {_price} to {price::%{_id}%} if {price::%{_id}%} is set else 0
    
    # Проверка статуса авто-продажи
    set {_auto} to "§cВЫКЛ"
    if {autosell::%{_u}%::%{_id}%} is true:
        set {_auto} to "§aВКЛ"
    
    add "" to {_l::*}
    add " §7Цена за штуку: §e%{_price}% ¥" to {_l::*}
    add " §7Авто-продажа: %{_auto}%" to {_l::*}
    add "" to {_l::*}
    add " §fВыберите количество:" to {_l::*}
    
    if {_m} is 1:
        add "  §e§l▶ §fПродать §61 шт. §e§l◀" to {_l::*}
    else:
        add "  §8◦ §7Продать 1 шт." to {_l::*}
    if {_m} is 16:
        add "  §e§l▶ §fПродать §616 шт. §e§l◀" to {_l::*}
    else:
        add "  §8◦ §7Продать 16 шт." to {_l::*}
    if {_m} is 32:
        add "  §e§l▶ §fПродать §632 шт. §e§l◀" to {_l::*}
    else:
        add "  §8◦ §7Продать 32 шт." to {_l::*}
    if {_m} is 64:
        add "  §e§l▶ §fПродать §664 шт. §e§l◀" to {_l::*}
    else:
        add "  §8◦ §7Продать 64 шт." to {_l::*}
    if {_m} is 0:
        add "  §e§l▶ §fПродать §6всё §e§l◀" to {_l::*}
    else:
        add "  §8◦ §7Продать всё" to {_l::*}
        
    add "" to {_l::*}
    add " §fДействия:" to {_l::*}
    add "  §eЛКМ §8» §7Продать выбранное" to {_l::*}
    add "  §eПКМ §8» §7Сменить количество" to {_l::*}
    add "  §eКл. Q §8» §fАвто-продажа §8(§7Toggle§8)" to {_l::*}
    add "" to {_l::*}
    
    set slot {_s} of {_p}'s current inventory to {_i} named "%{_n}%" with lore {_l::*}
    

    
    
command /sellgui:
    trigger:
        set {_gui} to a new chest inventory with 5 rows named "Скупщик ресурсов"
        open {_gui} to player
        set slot (integers between 0 and 44) of player's current inventory to gray stained glass pane named "§x§6§B§0§0§F§F§l§oP§x§B§C§8§3§F§F§l§oL"
        updateSellGUI(player)



# --- НАСТРОЙКА ЦЕН И БУСТЕРОВ ---
on load:
    set {price::cobblestone} to 0.5
    set {price::stone} to 0.8
    set {price::deepslate} to 1.0
    set {price::tuff} to 1.0
    set {price::netherrack} to 0.3
    set {price::basalt} to 0.5
    set {price::coal} to 3.0
    set {price::iron_ingot} to 15.0
    set {price::copper_ingot} to 8.0
    set {price::gold_ingot} to 25.0
    set {price::gold_nugget} to 2.5 # <--- Добавил цену
    set {price::lapis_lazuli} to 12.0
    set {price::redstone} to 10.0
    set {price::quartz} to 7.0
    set {price::diamond} to 100.0
    set {price::emerald} to 150.0
    set {price::ancient_debris} to 800.0

function updateSellGUI(p: player):
    # Ряд 1-2: Обычные ресурсы
    setSellItem({_p}, 10, cobblestone, "§7Булыжник")
    setSellItem({_p}, 11, stone, "§7Камень")
    setSellItem({_p}, 12, deepslate, "§8Глубинный сланец")
    setSellItem({_p}, 13, tuff, "§8Туф")
    setSellItem({_p}, 14, netherrack, "§cНезерак")
    setSellItem({_p}, 15, basalt, "§8Базальт")
    setSellItem({_p}, 16, coal, "§8Уголь")
    
    # Ряд 3: Слитки и основные руды
    setSellItem({_p}, 19, iron ingot, "§fЖелезо")
    setSellItem({_p}, 20, copper ingot, "§6Медь")
    setSellItem({_p}, 21, gold ingot, "§6Золото")
    setSellItem({_p}, 22, gold nugget, "§eЗолотой самородок")
    setSellItem({_p}, 23, quartz, "§fКварц")

    # Ряд 4: Драгоценности (как ты просил - в одну строчку)
    setSellItem({_p}, 28, lapis lazuli, "§9Лазурит")
    setSellItem({_p}, 29, redstone, "§cРедстоун")
    setSellItem({_p}, 30, diamond, "§bАлмаз")
    setSellItem({_p}, 31, emerald, "§aИзумруд")
    setSellItem({_p}, 32, ancient debris, "§4Древние обломки")
    
    set {_u} to uuid of {_p}
    
# --- Кнопка: АВТО-ПРОДАЖА ВСЕГО (Палка с Custom ID) ---
    set {_all_enabled} to true
    loop {price::*}:
        if {autosell::%{_u}%::%loop-index%} is not set:
            set {_all_enabled} to false
            
    if {_all_enabled} is false:
        set {_item} to stick with custom model data 5611101
        set {_status} to "§aВКЛЮЧИТЬ"
    else:
        set {_item} to stick with custom model data 5611102
        set {_status} to "§cВЫКЛЮЧИТЬ"
            
    set {_all_lore::*} to ""
    add " §7Массовое управление авто-продажей." to {_all_lore::*}
    add "" to {_all_lore::*}
    add " §fДействие: %{_status}% для всех ресурсов" to {_all_lore::*}
    add "" to {_all_lore::*}
    add " §eНажми, чтобы изменить!" to {_all_lore::*}
    set slot 34 of {_p}'s current inventory to {_item} named "§6§lАВТО-ПРОДАЖА: ВСЁ" with lore {_all_lore::*}
    
   
    
# ... внутри функции updateSellGUI ...
    set {_u} to uuid of {_p}
    set {_multiplier} to getMultiplier({_p})
    set {_total} to {stats::sell::%{_u}%}
    
    # Формируем красивую строку множителя
    set {_m_display} to "§e%{_multiplier}%x"
    if {booster::global} is set:
        set {_m_display} to "%{_m_display}% §8(§aГлобальный§8)"
    else if {booster::personal::%{_u}%} is set:
        set {_m_display} to "%{_m_display}% §8(§6Бустер§8)"

    # Книга статистики
    set slot 4 of {_p}'s current inventory to book named "§6§lВаша Статистика" with lore "" and " §fМножитель: %{_m_display}%" and " §fВсего заработано: §a%{_total}% ¥"
    # --- Кнопка: ПРОДАТЬ ВЕСЬ ИНВЕНТАРЬ (Tropical Fish) ---
    set {_fish} to tropical fish with custom model data 72214
    set slot 40 of {_p}'s current inventory to {_fish} named "§a§lПРОДАТЬ ВЕСЬ ИНВЕНТАРЬ" with lore "" and " §eНажми, чтобы очистить инвентарь!"
    set slot 36 of {_p}'s current inventory to paper with custom model data 10184 named "§c§l« Назад"


