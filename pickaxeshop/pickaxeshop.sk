        add "" to {_l4::*}
        add "§e» Нажмите для покупки" to {_l4::*}
        set slot 14 of {_gui} to raw iron block named "§f§lЖелезная лихорадка" with lore {_l4::*}
        
        # 5. ЭПИЧЕСКАЯ (EPIC)
        set {_l5::*} to "§7Золото и драгоценности повсюду.", "", "§fСостав блоков:"
        add " §8• §8Сланец §e(40%%)" to {_l5::*}
        add " §8• §eЗолотая руда §e(30%%)" to {_l5::*}
        add " §8• §bАлмазная руда §e(20%%)" to {_l5::*}
        add " §8• §aИзумрудная руда §e(10%%)" to {_l5::*}
        add "" to {_l5::*}
        add "§6Стоимость: §e80,000 ¥" to {_l5::*}
        add "" to {_l5::*}
        add "§e» Нажмите для покупки" to {_l5::*}
        set slot 15 of {_gui} to gold ore named "§d§lЭпическая шахта" with lore {_l5::*}
        
        # 6. АЛМАЗНАЯ (ULTRA)
        set {_l6::*} to "§bЧистые алмазы. Ничего лишнего.", "", "§fСостав блоков:"
        add " §8• §7Глубинный сланец §e(55%%)" to {_l6::*}
        add " §8• §bАлмазная руда §e(45%%)" to {_l6::*}
        add "" to {_l6::*}
        add "§6Стоимость: §e85,000 ¥" to {_l6::*}
        add "" to {_l6::*}
        add "§b§lЛЕГЕНДАРНЫЙ ВЫБОР" to {_l6::*}
        add "§e» Нажмите для покупки" to {_l6::*}
        set slot 16 of {_gui} to diamond ore named "§b§lАЛМАЗНАЯ ШАХТА" with lore {_l6::*}
        set slot 18 of {_gui} to paper with custom model data 10184 named "§c§l« Назад"
        open {_gui} to player

on inventory click:
    if name of event-inventory is "§8⭐ Выбор режима шахты":
        cancel event
        set {_u} to uuid of player
        
        if index of event-slot is 10:
            set {_price} to 9000
            set {_type} to "default"
            set {_name} to "§fОбычную"
        else if index of event-slot is 11:
            set {_price} to 16000
            set {_type} to "super"
            set {_name} to "§6Редкую"
        else if index of event-slot is 12:
            set {_price} to 35000
            set {_type} to "builder"
            set {_name} to "§eСтроительную"
        else if index of event-slot is 14:
            set {_price} to 63000
            set {_type} to "iron_rush"
            set {_name} to "§fЖелезную"
        else if index of event-slot is 15:
            set {_price} to 80000
            set {_type} to "epic"
            set {_name} to "§dЭпическую"
        else if index of event-slot is 16:
            set {_price} to 85000
            set {_type} to "ultra"
            set {_name} to "§bАлмазную"
        else if index of event-slot is 18:
            execute player command "pickaxeshop"
            stop
        else:
            stop

        set {_raw_bal} to "%player's balance%"
        replace all "," and "¥" and "$" and " " with "" in {_raw_bal}
        set {_split::*} to {_raw_bal} split at "."
        set {_final_bal} to {_split::1} parsed as number
        
        if {_final_bal} >= {_price}:
            remove {_price} from player's balance
            execute console command "automine set zxc %{_type}%"
            
            send "§a§lШАХТА §8» §fВы активировали %{_name}% §fшахту!" to player
            play sound "entity.player.levelup" with volume 1 and pitch 1 to player
            
            if {_price} >= 80000:
                broadcast ""
                broadcast "  §6§lВНИМАНИЕ! §fИгрок §e%player% §fустановил режим %{_name}% §fшахты!"
                broadcast "  §7Все бегом в шахту, время ограничено! ⛏"
                broadcast ""
            
            close player's inventory
        else:
            send "§cНедостаточно средств!" to player
            play sound "entity.villager.no" with volume 1 and pitch 1 to player