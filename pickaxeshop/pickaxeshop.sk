        add "" to {_l2::*}
        add "§e» Нажмите для покупки" to {_l2::*}
        set slot 11 of {_gui} to iron ore named "§6§lРедкая шахта" with lore {_l2::*}
        
        # 3. СТРОИТЕЛЬНАЯ (BUILDER)
        set {_l3::*} to "§7Рай для строителя и декоратора.", "", "§fСостав блоков:"
