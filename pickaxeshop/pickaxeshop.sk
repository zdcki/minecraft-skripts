function formatTime(t: timespan) :: text:
    set {_total} to (ticks of {_t} / 20) # Превращаем тики в секунды (самый стабильный метод)
    set {_m} to floor({_total} / 60)
    set {_s} to floor({_total} mod 60)
    
    if {_s} < 10:
        return "%{_m}%:0%{_s}%"
    return "%{_m}%:%{_s}%"


# --- ФУНКЦИЯ ПОКУПКИ ---
function buyPickaxe(p: player, price: number, item: item):
    set {_raw_bal} to "%{_p}'s balance%"
    replace all "," and "¥" and "$" and " " with "" in {_raw_bal}
    set {_split::*} to {_raw_bal} split at "."
    set {_final_bal} to {_split::1} parsed as number
    
    if {_final_bal} >= {_price}:
        if {_p} has enough space for {_item}:
            remove {_price} from {_p}'s balance
            
            set {_l::*} to lore of {_item}
            add "" to {_l::*}
            add "§8» §fВладелец: §7%{_p}%" to {_l::*}
            set lore of {_item} to {_l::*}
            
            give {_item} to {_p}
            send action bar "§a§l✔ §fПриобретено! §8(§e-%{_price}% ¥§8)" to {_p}
            play sound "entity.player.levelup" with volume 0.4 and pitch 2 at {_p}
            
            if {_price} == 200000:
                broadcast "§d§lМАГАЗИН §8» §fИгрок §d%display name of {_p}% §fприобрел §5§lСЕРДЦЕ СЕРВЕРА§f!"
                play sound "ui.toast.challenge_complete" with volume 1 and pitch 1 to all players
        else:
            send action bar "§c§l✕ §fИнвентарь заполнен!" to {_p}
    else:
        send action bar "§c§l✕ §fНедостаточно средств!" to {_p}
        play sound "block.note_block.bass" with volume 1 and pitch 1 to {_p}

# --- ЭФФЕКТ ПРИ КОПАНИИ (Спешка) ---
on mine:
    if player's tool is a netherite pickaxe:
        if name of player's tool contains "СЕРДЦЕ СЕРВЕРА":
            chance of 10%:
                apply haste 2 to player for 6 seconds
                send action bar "§e⚡ Энергия недр: Спешка II" to player



function getMultiplier(p: player) :: number:
    set {_m} to 1.0
    
    # Донат
    if {_p} has permission "taysa.skript":
        set {_m} to 1.5
    else if {_p} has permission "gunso.skript":
        set {_m} to 1.2
        
    # Глобальный (прибавляем 0.5 к базе)
    if {booster::global} is set:
        add 0.5 to {_m}
        
    # Личный (прибавляем 0.5 или 1.0)
    set {_u} to uuid of {_p}
    if {booster::personal::%{_u}%} is set:
        set {_val} to {booster::personal::%{_u}%} - 1.0
        add {_val} to {_m}
        
    return {_m}



# --- МЕНЮ МАГАЗИНА ---
command /pickaxeshop1:

    trigger:
        set {_gui} to a new chest inventory with 4 rows named "Магазин инструментов"
        set slot (integers between 0 and 35) of {_gui} to gray stained glass pane named "§x§6§B§0§0§F§F§l§oP§x§B§C§8§3§F§F§l§oL"
        
        set {_bal} to player's balance
        set slot 4 of {_gui} to emerald named "§a§lВаш Баланс" with lore "§fНа вашем счету: §e%{_bal}% ¥"
        
        # Кирки (твои зачарования)
        set slot 10 of {_gui} to diamond pickaxe of efficiency 2 named "§b§lАлмазка: Уровень 1" with lore "§7Начальный инструмент", "", "§eЦена: 1500 ¥"
        set slot 11 of {_gui} to diamond pickaxe of efficiency 3 named "§b§lАлмазка: Уровень 2" with lore "§7Чуть быстрее", "", "§eЦена: 3500 ¥"
        set slot 12 of {_gui} to diamond pickaxe of efficiency 4 and unbreaking 2 named "§b§lАлмазка: Уровень 3" with lore "§7Надёжная классика", "", "§eЦена: 7000 ¥"
        set slot 13 of {_gui} to diamond pickaxe of efficiency 5 named "§b§lАлмазка: Мастер" with lore "§7Максимальная скорость", "", "§eЦена: 12000 ¥"
        set slot 14 of {_gui} to diamond pickaxe of efficiency 5 and fortune 2 named "§b§lАлмазка: Ресурсник" with lore "§7Больше руды", "", "§eЦена: 22000 ¥"
        set slot 15 of {_gui} to diamond pickaxe of efficiency 5 and silk touch named "§b§lАлмазка: Ювелир" with lore "§7Для целых блоков", "", "§eЦена: 28000 ¥"
        set slot 16 of {_gui} to diamond pickaxe of efficiency 5, fortune 3 and unbreaking 3 named "§b§l§nАЛМАЗНЫЙ ИДЕАЛ" with lore "§fЛучшая из возможных", "", "§eЦена: 50000 ¥"

        set slot 19 of {_gui} to netherite pickaxe of efficiency 4 named "§6§lНезеритка: Старт" with lore "§7Прочность недр", "", "§eЦена: 75000 ¥"
        set slot 20 of {_gui} to netherite pickaxe of efficiency 5 and unbreaking 3 named "§6§lНезеритка: Стойкость" with lore "§7Долгая работа", "", "§eЦена: 90000 ¥"
        set slot 21 of {_gui} to netherite pickaxe of efficiency 5 and silk touch named "§6§lНезеритка: Шёлк" with lore "§7Бережное касание", "", "§eЦена: 110000 ¥"
        set slot 22 of {_gui} to netherite pickaxe of efficiency 5, fortune 3 and unbreaking 3 named "§6§lНезеритка: Удача" with lore "§7Король добычи", "", "§eЦена: 135000 ¥"
        set slot 23 of {_gui} to netherite pickaxe of efficiency 5, fortune 3, unbreaking 3 and mending named "§6§lНезеритка: Вечность" with lore "§7Самосборная кирка", "", "§eЦена: 160000 ¥"
        set slot 24 of {_gui} to netherite pickaxe of efficiency 5, silk touch, unbreaking 3 and mending named "§4§lМОНОЛИТ" with lore "§cНеразрушимый шёлк", "", "§eЦена: 180000 ¥"
        set slot 25 of {_gui} to netherite pickaxe of efficiency 5, fortune 3, unbreaking 3 and mending named "§d§lСЕРДЦЕ СЕРВЕРА" with lore "§dСамый ценный артефакт", "", "§eЦена: 200000 ¥"

        # ПРИКОЛЮХИ
        #set slot 31 of {_gui} to bundle named "§d§lКИРКА-СЮРПРИЗ" with lore "§fИспытай удачу!", "§7Может выпасть любая кирка из магазина", "", "§eЦена: 45000 ¥"
        # Незеритовая кирка (Разрушитель спавнеров)
        set {_lore_spawner} to "§7Забытая кузнечная мощь||§fПозволяет сломать §e1 спавнер§f||§fТип спавнера сохраняется!||§f||§eЦена: 350000 ¥"
        set {_l_sp::*} to {_lore_spawner} split at "||"
        set slot 34 of {_gui} to netherite pickaxe named "§4§lРазрушитель Спавнеров" with lore {_l_sp::*}
        # СТРЕЛКА К СКУПЩИКУ
        #set {_item} to stick with custom model data 5611102
        set slot 27 of {_gui} to paper with custom model data 10184 named "§c§l« Назад"
                # Золотая кирка (Бедроколом)
        set {_lore_bedrock} to "§7Древняя магия золота||§fПозволяет сломать §e1 блок §fбедрока||§f||§eЦена: 250000 ¥"
        set {_l_br::*} to {_lore_bedrock} split at "||"
        set slot 33 of {_gui} to golden pickaxe named "§6§lРазрушитель Бедрока" with lore {_l_br::*}
        open {_gui} to player


