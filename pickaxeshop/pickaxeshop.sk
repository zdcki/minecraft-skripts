# --- ОБРАБОТКА КЛИКОВ (ПОЛНАЯ ВЕРСИЯ) ---
on inventory click:
    if name of event-inventory is "Скупщик ресурсов":
        cancel event
        if clicked inventory is player's inventory:
            stop
        if event-item is air or gray stained glass pane:
            stop

        set {_u} to uuid of player
        set {_id} to "%type of event-item%"
        replace all " " with "_" in {_id}

        # --- КНОПКА: НАЗАД (36 слот) ---
        if index of event-slot is 36:
            execute player command "pickaxeshop"
            stop

# Клик по кнопке "Авто-продажа ВСЁ" (34 слот)
        if index of event-slot is 34:
            set {_turn_on} to true
            if item amount of (slot 34 of player's current inventory) is 1: # Простая проверка по модели
                if custom model data of event-item is 5611102:
                    set {_turn_on} to false

            loop {price::*}:
                if {_turn_on} is true:
                    set {autosell::%{_u}%::%loop-index%} to true
                else:
                    delete {autosell::%{_u}%::%loop-index%}
            
            updateSellGUI(player)
            play sound "block.lever.click" to player
            stop

        # --- НАЖАТИЕ КЛАВИШИ Q (ТОЧЕЧНАЯ АВТО-СКУПКА) ---
        if "%click type%" contains "drop":
            if {price::%{_id}%} is set:
                if {autosell::%{_u}%::%{_id}%} is not set:
                    set {autosell::%{_u}%::%{_id}%} to true
                    send "§d§lСКУПЩИК §8» §fАвто-продажа для предмета §aВКЛЮЧЕНА" to player
                else:
                    delete {autosell::%{_u}%::%{_id}%}
                    send "§d§lСКУПЩИК §8» §fАвто-продажа для предмета §cВЫКЛЮЧЕНА" to player
                
                play sound "block.note_block.bit" with volume 0.5 and pitch 2 to player
                updateSellGUI(player)
            stop

        # Расчет множителя (для ЛКМ и Воронки)
        set {_m} to getMultiplier(player)
        #send "%{_m}%" to player

        # --- ПКМ: ПЕРЕКЛЮЧЕНИЕ РЕЖИМА КОЛИЧЕСТВА ---
        if click type is right mouse button:
            if index of event-slot is 40: # Игнорируем воронку
                stop
            if {sellmode::%{_u}%} is not set:
                set {sellmode::%{_u}%} to 1
            
            if {sellmode::%{_u}%} is 1:
                set {sellmode::%{_u}%} to 16
            else if {sellmode::%{_u}%} is 16:
                set {sellmode::%{_u}%} to 32
            else if {sellmode::%{_u}%} is 32:
                set {sellmode::%{_u}%} to 64
            else if {sellmode::%{_u}%} is 64:
                set {sellmode::%{_u}%} to 0
            else:
                set {sellmode::%{_u}%} to 1
            updateSellGUI(player)
            play sound "ui.button.click" with volume 0.5 and pitch 2 to player
            stop

        # --- ЛКМ: ПРОДАЖА ---
        if click type is left mouse button:
            # 1. ПРОДАТЬ ВЕСЬ ИНВЕНТАРЬ (Воронка)
            if index of event-slot is 40:
                set {_total} to 0
                set {_has_trash} to false
                clear {_summary::*} # Очищаем список для отчета
                
                loop all items in player's inventory:
                    set {_i_id} to "%type of loop-item%"
                    set {_raw} to {_i_id}
                    replace all " " with "_" in {_raw}
                    if {price::%{_raw}%} is set:
                        set {_a} to item amount of loop-item
                        add ({_a} * {price::%{_raw}%} * {_m}) to {_total}
                        # Добавляем в отчет
                        add {_a} to {_summary::%{_i_id}%}
                        remove loop-item from player's inventory
                    else if loop-item is not air:
                        set {_has_trash} to true
                
                if {_total} > 0:
                    add {_total} to player's balance
                    add {_total} to {stats::sell::%{_u}%}
                    
                    # Формируем список проданного для чата
                    set {_report} to ""
                    loop {_summary::*}:
                        set {_name} to loop-index
                        set {_amt} to loop-value
                        set {_report} to "%{_report}%§e%{_name}% §8(§fx%{_amt}%§8)§7, "
                    
                    # Убираем лишнюю запятую в конце
                    set {_report} to subtext of {_report} from 1 to (length of {_report} - 2)
                    
                    send "" to player
                    send "  §d§lСКУПЩИК §8» §fВы очистили инвентарь!" to player
                    send "  §fПродано: %{_report}%" to player
                    send "  §fВыручка: §a+ %{_total}% ¥ §8(§ex%{_m}%§8)" to player
                    send "" to player
                    
                    play sound "block.amethyst_block.break" with volume 1 and pitch 1.5 to player
                    if {_has_trash} is true:
                        send "  §8(§7В инвентаре остались предметы, которые не скупаются§8)" to player
                    updateSellGUI(player)
                else:
                    send "§d§lСКУПЩИК §8» §cУ вас нет ресурсов для продажи!" to player
                    play sound "block.note_block.bass" with volume 1 and pitch 1 to player
                stop

            # 2. ПРОДАЖА ОДНОГО ТИПА (Клик по предмету)
            set {_m_string} to "%type of event-item%"
            set {_found} to 0
            loop all items in player's inventory:
                if "%type of loop-item%" is {_m_string}:
                    add item amount of loop-item to {_found}
            #send "%{_m}% 0" to player

            if {_found} > 0:
                set {_amount_mode} to {sellmode::%{_u}%} if {sellmode::%{_u}%} is set else 1
                #send "%{_m}% 1" to player
                if {_amount_mode} is 0:
                    set {_to_sell} to {_found}
                    #send "%{_m}% 2" to player
                else if {_found} >= {_amount_mode}:
                    set {_to_sell} to {_amount_mode}
                    #send "%{_m}% 3" to player
                else:
                    set {_to_sell} to {_found}
                    #send "%{_m}% 4" to player
                
                set {_rem} to {_to_sell}
                loop all items in player's inventory:
                    if {_rem} > 0:
                        if "%type of loop-item%" is {_m_string}:
                            if item amount of loop-item <= {_rem}:
                                set {_rem} to {_rem} - item amount of loop-item
                                remove loop-item from player's inventory
                            else:
                                set item amount of loop-item to (item amount of loop-item - {_rem})
                                set {_rem} to 0
                set {_raw} to {_m_string}
                replace all " " with "_" in {_raw}
                
                # Теперь {_to_sell} - это сколько штук, 
                # {price::%{_raw}%} - цена за штуку,
                # {_m} - твой денежный множитель из функции.
                set {_gain} to ({_to_sell} * {price::%{_raw}%} * {_m})
                
                add {_gain} to player's balance
                add {_gain} to {stats::sell::%{_u}%}
                
                send "§d§lСКУПЩИК §8» §fПродано: §e%{_m_string}% §8(§fx%{_to_sell}%§8) §fна §a+ %{_gain}% ¥ §8(§7x%{_m}%§8)" to player
                play sound "entity.experience_orb.pickup" to player
                updateSellGUI(player)
            else:
                send "§d§lСКУПЩИК §8» §cНечего продавать!" to player
                play sound "block.note_block.bass" with volume 1 and pitch 1 to player


# --- АВТО-ПРОДАЖА В РЕГИОНЕ (ДЛЯ ВЫДАВАЕМЫХ ПРЕДМЕТОВ) ---
every 10 tick:
    loop all players:
        # Проверяем, находится ли игрок в регионе take1
        # (Требуется WorldGuard + Skript-WorldGuard или аналог)
        set {_rg} to "%region at loop-player%"
        if {_rg} contains "take1" or "take3":
            
            set {_u} to uuid of loop-player
            

            set {_m} to getMultiplier(loop-player)
            set {_total_gain} to 0
            set {_any_sold} to false
            
            # Проверяем инвентарь на наличие предметов из списка цен
            loop all items in loop-player's inventory:
                set {_id} to "%type of loop-item%"
                replace all " " with "_" in {_id}
                
                # Если цена установлена и включена авто-продажа для этого ID
                if {price::%{_id}%} is set:
                    if {autosell::%{_u}%::%{_id}%} is true:
                        
                        set {_amt} to item amount of loop-item
                        set {_gain} to ({_amt} * {price::%{_id}%} * {_m})
                        
                        add {_gain} to {_total_gain}
                        remove loop-item from loop-player's inventory
                        set {_any_sold} to true
            
            # Если что-то продали — начисляем деньги и пишем в Action Bar
            if {_any_sold} is true:
                add {_total_gain} to loop-player's balance
                add {_total_gain} to {stats::sell::%{_u}%}
                send action bar "§d§lАВТО-ШАХТА §8» §fПродано ресурсов на §a+ %{_total_gain}% ¥" to loop-player



on left click on bedrock:
    # Проверяем, что в руках золотая кирка с нужным названием
    if player's tool is golden pickaxe:
        if name of player's tool contains "§6§lРазрушитель Бедрока":
            # Разрешаем ломать блок в режиме выживания
            cancel event
            set event-block to air
            
            # Эффекты разрушения
            play sound "block.ancient_debris.break" with volume 1 and pitch 0.5 at player
            play sound "entity.item.break" with volume 1 and pitch 1 at player
            show huge explosion at event-block
            
            # Удаляем кирку (одноразовое использование)
            remove 1 of player's tool from player's inventory
            send action bar "§6§l⚡ §fМагия исчерпана: Бедрок разрушен!" to player
        else:
            if player's gamemode is survival:
                cancel event
                send action bar "§cЭтот блок невозможно сломать обычной киркой!" to player
                
    else:
        if player's gamemode is survival:
            cancel event



# --- 1. ДОБЫЧА СПАВНЕРА ---
on left click on spawner:
    if name of player's tool is "§4§lРазрушитель Спавнеров":
        if player cannot build at event-block:
            send "§c§l[DEBUG] §fНет прав в регионе!" to console
            cancel event
            stop
        
        # Читаем NBT блока
        set {_nbt} to nbt compound of event-block
        set {_mob} to string tag "SpawnData;entity;id" of {_nbt}
        
        if {_mob} is not set:
            set {_mob} to "minecraft:pig"
            send "§e[DEBUG] §fМоб не найден в блоке, ставим по умолчанию: pig" to console
        else:
            send "§a[DEBUG] §fИз блока извлечен моб: %{_mob}%" to console
            
        cancel event
        set event-block to air
        
        # Выдача предмета (1.21.4 формат)
        # Мы сохраняем моба ТРЕМЯ разными способами для надежности
        execute console command "minecraft:give %player% spawner[custom_data={saved_mob:""%{_mob}%""},item_name='""§6§lМагический Спавнер""',lore=['""§7Моб: §e%{_mob}%""','""§0MOB:%{_mob}%""']] 1"
        
        send "§b[DEBUG] §fКоманда give отправлена. Проверьте Lore предмета!" to console
        remove 1 of player's tool from player's inventory

# --- 2. УСТАНОВКА СПАВНЕРА ---
on place of spawner:
    # Считываем моба из Lore
    set {_lore::*} to lore of player's tool
    loop {_lore::*}:
        if loop-value contains "§0MOB:":
            set {_mob} to loop-value
            replace all "§0MOB:" with "" in {_mob}
            stop loop
    
    if {_mob} is set:
        set {_x} to floor(x-coord of event-block)
        set {_y} to floor(y-coord of event-block)
        set {_z} to floor(z-coord of event-block)
        
        # Сначала убираем блок, чтобы избежать ошибки "Could not set"
        set event-block to air
        
        # Ждем 1 тик и ставим "правильный" спавнер
        wait 1 tick
        set {_cmd} to "minecraft:setblock %{_x}% %{_y}% %{_z}% spawner{SpawnData:{entity:{id:""%{_mob}%""}}} replace"
        execute console command {_cmd}
        
        # Эффект для подтверждения
        play sound "block.amethyst_block.chime" with volume 0.5 and pitch 2 at event-block
    else:
        send "§c[!] Ошибка: Данные моба не найдены." to console


command /boosters:
    aliases: /бустеры, /boost
    trigger:
        set {_gui} to chest inventory with 3 rows named "§8Меню бустеров"
        set {_u} to uuid of player
        set slot (all integers from 0 to 26) of {_gui} to gray stained glass pane named "§x§6§B§0§0§F§F§l§oP§x§B§C§8§3§F§F§l§oL"
        
# --- ЛОГИКА ЧАСОВ (СЛОТ 4) ---
        set {_personal_time} to "§cНе активен"
        set {_global_time} to "§cНе активен"
        
        # Личный бустер
        if {booster::personal::time::%{_u}%} is set:
            set {_passed} to difference between {booster::personal::time::%{_u}%} and now
            set {_dur} to 10 minutes if {booster::personal::%{_u}%} is 1.5 else 30 minutes
            
            if {_passed} < {_dur}:
                set {_left} to difference between {_dur} and {_passed}
                # Добавляем отображение множителя (1.5x или 2.0x)
                set {_m_val} to {booster::personal::%{_u}%}
                set {_personal_time} to "§aАктивен §e%{_m_val}%x §8(§f%formatTime({_left})%§8)"
        
        # Глобальный бустер
        if {booster::global::time} is set:
            set {_passed} to difference between {booster::global::time} and now
            if {_passed} < 15 minutes:
                set {_left} to difference between 15 minutes and {_passed}
                # Глобальный у нас всегда 1.5x по твоему коду
                set {_global_time} to "§aАктивен §e1.5x §8(§f%formatTime({_left})%§8)"

        set slot 4 of {_gui} to clock named "§6§lСтатус Бустеров" with lore "", " §fЛичный: %{_personal_time}%", " §fГлобальный: %{_global_time}%", ""
        
        # --- ОСТАЛЬНЫЕ ПРЕДМЕТЫ (как у тебя) ---
        set {_l1::*} to "§7Увеличивает твой доход в §e1.5 раза", "§7Действует: §f10 минут","§7Только на предметы в §fшахте", " §7И §f/autosell", "§eЦена: 25,000 ¥"
        if {booster::personal::%{_u}%} is set:
            add "§c§lУЖЕ АКТИВИРОВАН" to {_l1::*}
        set {_i} to potion of fire resistance named "§6§lЛичный Бустер §e1.5x" with lore {_l1::*}
        add hide attributes and hide additional tooltip to item flags of {_i}
        set slot 11 of {_gui} to {_i}
        
        set {_l2::*} to "§7Увеличивает твой доход в §e2.0 раза", "§7Действует: §f30 минут","§7Только на предметы в §fшахте", " §7И §f/autosell", "§eЦена: 100,000 ¥"
        if {booster::personal::%{_u}%} is set:
            add "§c§lУЖЕ АКТИВИРОВАН" to {_l2::*}
        set {_i2} to potion of swiftness named "§d§lЛичный Бустер §e2.0x" with lore {_l2::*}
        add hide attributes and hide additional tooltip to item flags of {_i2}
        set slot 13 of {_gui} to {_i2}
        
        set {_lg::*} to "§7Увеличивает доход §aВСЕХ §7игроков", "§7Действует: §f15 минут","§7Только на предметы в §fшахте", " §7И §f/autosell", "§eЦена: 200,000 ¥"
        if {booster::global} is set:
            add "§c§lУЖЕ АКТИВИРОВАН" to {_lg::*}
        set {_ig} to splash potion of regeneration named "§a§lГлобальный Бустер §e1.5x" with lore {_lg::*}
        add hide attributes and hide additional tooltip to item flags of {_ig}
        set slot 15 of {_gui} to {_ig}
        
        set slot 18 of {_gui} to paper with custom model data 10184 named "§c§l« Назад"
        
        open {_gui} to player

# --- ОБРАБОТКА КЛИКОВ В БУСТЕРАХ ---
on inventory click:
    if name of event-inventory is "§8Меню бустеров":
        cancel event
        set {_u} to uuid of player
        if index of event-slot is 11 or 13 or 15 or 18:
            if index of event-slot is 11 or 13:
                if {booster::personal::%{_u}%} is set:
                    send "§cУ тебя уже есть активный личный бустер!" to player
                    stop
            else if index of event-slot is 15:
                if {booster::global} is set:
                    send "§cГлобальный бустер уже активен!" to player
                    stop
            else if index of event-slot is 18:
                execute player command "pickaxeshop"
                stop

            set {_price} to 0
            if index of event-slot is 11:
                set {_price} to 25000
            else if index of event-slot is 13:
                set {_price} to 100000
            else if index of event-slot is 15:
                set {_price} to 200000
            
            set {_raw_bal} to "%player's balance%"
            replace all "," and "¥" and "$" and " " with "" in {_raw_bal}
            set {_split::*} to {_raw_bal} split at "."
            set {_final_bal} to {_split::1} parsed as number
            
            if {_final_bal} >= {_price}:
                remove {_price} from player's balance
                if index of event-slot is 11:
                    set {booster::personal::%{_u}%} to 1.5
                    set {booster::personal::time::%{_u}%} to now # Запоминаем время
                    send "§6§lБУСТЕР-ШАХТЫ §8» §fАктивирован §e1.5x §fна 10 мин."
                    wait 10 minutes
                    delete {booster::personal::%{_u}%}
                    delete {booster::personal::time::%{_u}%}
                else if index of event-slot is 13:
                    set {booster::personal::%{_u}%} to 2.0
                    set {booster::personal::time::%{_u}%} to now # Запоминаем время
                    send "§d§lБУСТЕР-ШАХТЫ §8» §fАктивирован §e2.0x §fна 30 мин."
                    wait 30 minutes
                    delete {booster::personal::%{_u}%}
                    delete {booster::personal::time::%{_u}%}
                else if index of event-slot is 15:
                    set {booster::global} to 1.5
                    set {booster::global::time} to now # Запоминаем время
                    broadcast "§a§lГЛОБАЛЬНЫЙ БУСТЕР-ШАХТЫ §8» §a%player%§f включил §e1.5x §fдля всех на 15 мин!"
                    wait 15 minutes
                    delete {booster::global}
                    delete {booster::global::time}
                close player's inventory
            else:
                send "§cНедостаточно денег!" to player


command /boosteradmin [<text>] [<offline player>]:
    permission: admin.boosters
    permission message: §cУ вас нет прав на использование этой команды!
    description: Управление бустерами (сброс)
    aliases: /ba, /boostadmin
    trigger:
        # Если аргумент не указан
        if arg-1 is not set:
            send "" to player
            send "§d§lАдмин-Панель Бустеров" to player
            send "§f/ba §eresetglobal §7- Сбросить глобальный бустер" to player
            send "§f/ba §eresetplayer <ник> §7- Сбросить личный бустер игрока" to player
            send "§f/ba §eresetall §7- Полный сброс всех активных бустеров" to player
            send "" to player
            stop

        # Сброс ГЛОБАЛЬНОГО бустера
        if arg-1 is "resetglobal":
            if {booster::global} is set:
                delete {booster::global}
                broadcast "§c§lБУСТЕР-ШАХТЫ §8» §fГлобальный бустер был принудительно отключен администратором."
            else:
                send "§cГлобальный бустер и так не активен." to player

        # Сброс ЛИЧНОГО бустера игрока
        else if arg-1 is "resetplayer":
            if arg-2 is set:
                set {_u} to uuid of arg-2
                if {booster::personal::%{_u}%} is set:
                    delete {booster::personal::%{_u}%}
                    send "§aВы успешно сбросили личный бустер игроку §e%arg-2%§a." to player
                    if arg-2 is online:
                        send "§cВаш личный бустер был сброшен администратором." to arg-2
                else:
                    send "§cУ этого игрока нет активного бустера." to player
            else:
                send "§cУкажите ник игрока! §7(/ba resetplayer Ник)" to player

        # Полный сброс (Очистка всех переменных)
        else if arg-1 is "resetall":
            delete {booster::global}
            delete {booster::personal::*}
            delete {booster::personal::time::*}
            delete {booster::global::time}
            broadcast "§c§lБУСТЕР-ШАХТЫ §8» §fВсе активные бустеры на сервере были обнулены администратором."


command /mineszxc:
    trigger:
        set {_gui} to chest inventory with 3 rows named "§8⭐ Выбор режима шахты"
        set slot (all integers from 0 to 27) of {_gui} to gray stained glass pane named "§x§6§B§0§0§F§F§l§oP§x§B§C§8§3§F§F§l§oL"
        
        # 1. ОБЫЧНАЯ
