        add " §8• §bМорские фонари §e(10%%)" to {_l3::*}
        add " §8• §dАметист, Призмарин §e(10%%)" to {_l3::*}
        add " §8• §6Свет. камень, Магма §e(10%%)" to {_l3::*}
        add " §8• §fЛед, Медн. блоки §e(10%%)" to {_l3::*}
        add " §8• §fСтекло §e(5%%)" to {_l3::*}
        add "" to {_l3::*}
        add "§6Стоимость: §e35,000 ¥" to {_l3::*}
        add "" to {_l3::*}
        add "§e» Нажмите для покупки" to {_l3::*}
        set slot 12 of {_gui} to sea lantern named "§e§lСтроительный бум" with lore {_l3::*}
        
        # 4. ЖЕЛЕЗНАЯ ЛИХОРАДКА
        set {_l4::*} to "§7Огромные залежи чистого железа.", "", "§fСостав блоков:"
        add " §8• §fЖелезная руда §e(50%%)" to {_l4::*}
        add " §8• §fБлоки железа §e(20%%)" to {_l4::*}
        add " §8• §7Камень §e(30%%)" to {_l4::*}
