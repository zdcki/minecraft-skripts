        add " §8• §7Уголь §e(25%%)" to {_l1::*}
        add " §8• §6Медь §e(25%%)" to {_l1::*}
        add " §8• §7Камень §e(25%%)" to {_l1::*}
        add " §8• §8Сланец §e(15%%)" to {_l1::*}
