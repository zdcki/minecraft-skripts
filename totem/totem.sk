            set lore of {_i} to "&7Ранг: &6Колоссальный", "", "&e🛡 Способности:", " &8» &dОгромное здоровье &7(3 мин.)", " &8» &cСила III", "", "&6&o«Даже боги боятся твоей мощи.»"


# 33. БОГ
        else if arg-1 is "god":
