            set lore of {_i} to "&7Ранг: &bЗапрещенный", "", "&b💻 Способности:", " &8» &fПолная остановка времени &7(8с.)", " &8» &3Взлом реальности", "", "&3&o«Error 404: Mortality not found.»"

