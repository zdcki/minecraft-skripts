# --- НАСТРОЙКИ ТОТЕМОВ (ID для Custom Model Data) ---
options:
    # Твои старые
    berserk_id: 1001
    turtle_id: 1002
    # Новые (15 штук)
    phantom_id: 1003
    vampire_id: 1004
    miner_id: 1005
    thief_id: 1006
    paladin_id: 1007
    storm_id: 1008
    diver_id: 1009
    escape_id: 1010
    farmer_id: 1011
    reaper_id: 1012
    tank_id: 1013
    inferno_id: 1014
    medic_id: 1015
    frost_id: 1016
    luck_id: 1017

    scout_id: 1018
    gravity_id: 1019
    alchemist_id: 1020
    blacksmith_id: 1021
    archangel_id: 1022
    void_id: 1023
    ninja_id: 1024
    phoenix_id: 1025
    ocean_king_id: 1026
    berserk_v2_id: 1027
    trader_id: 1028
    ghost_id: 1029
    dragon_id: 1030
    hacker_id: 1031
    titan_id: 1032

    god_id: 1033
    reaper_v2_id: 1034
    anti_trap_id: 1035
    rich_id: 1036
    overlord_id: 1037
    
on damage of player:
    if attacker is a player:
        set metadata value "last_attacker" of victim to attacker
    
# --- ЛОГИКА АКТИВАЦИИ ---
on resurrect:
    # 1. Проверяем правую руку
    set {_item} to player's tool
    set {_cmd} to custom model data of {_item}
    
    # Если в правой руке пусто или ID не наш, проверяем левую
    if {_cmd} is not set:
        set {_item} to player's offhand tool
        set {_cmd} to custom model data of {_item}
    else if {_cmd} < 1001:
        set {_item} to player's offhand tool
        set {_cmd} to custom model data of {_item}
    else if {_cmd} > 1037:
        set {_item} to player's offhand tool
        set {_cmd} to custom model data of {_item}
        
    # 2. Финальная проверка: если после всех манипуляций ID всё еще не подходит - стоп
    if {_cmd} is not set:
        stop
    if {_cmd} < 1001:
        stop
    if {_cmd} > 1037:
        stop

    # Если дошли сюда, значит тотем наш.
    wait 2 ticks

    # 1. ТОТЕМ БЕРСЕРКА
    if {_cmd} is {@berserk_id}:
        apply strength 2 to player for 60 seconds
        apply haste 2 to player for 60 seconds
        send "&6&l⚡ &fЯрость берсерка пробуждена!" to player
        play sound "entity.ender_dragon.growl" with pitch 1.5 to player

    # 2. ТОТЕМ ЧЕРЕПАХИ
    else if {_cmd} is {@turtle_id}:
        apply resistance 3 to player for 45 seconds
        apply slowness 2 to player for 20 seconds
        send "&a&l🐢 &fПанцирь черепахи защитил вас!" to player
        play sound "item.armor.equip_netherite" with pitch 0.5 to player

    # 3. ТОТЕМ ФАНТОМА (Невидимость и Полет)
    else if {_cmd} is {@phantom_id}:
        apply invisibility 1 to player for 30 seconds
        apply speed 3 to player for 30 seconds
        apply jump boost 3 to player for 30 seconds
        send "&f&l👻 &fВы стали бесплотным духом..." to player
        play sound "entity.phantom.ambient" to player

    # 4. ТОТЕМ ВАМПИРА (Восстановление за счет урона)
    else if {_cmd} is {@vampire_id}:
        apply health boost 4 to player for 2 minutes
        apply regeneration 3 to player for 15 seconds
        send "&c&l🩸 &fЖажда крови утолена!" to player
        play sound "entity.bat.ambient" to player

    # 5. ТОТЕМ ШАХТЕРА
    else if {_cmd} is {@miner_id}:
        apply haste 3 to player for 5 minutes
        apply night vision 1 to player for 5 minutes
        send "&e&l⚒ &fСила недр наполняет ваши инструменты!" to player
        play sound "block.anvil.land" with pitch 1.5 to player

    # 6. ТОТЕМ ВОРА (Ослепление врагов вокруг)
    else if {_cmd} is {@thief_id}:
        loop players in radius 7 around player:
            apply blindness 1 to loop-player for 5 seconds
        apply speed 4 to player for 10 seconds
        send "&7&l👤 &fВы скрылись в тенях, ослепив врагов!" to player
        play sound "entity.illusioner.cast_spell" to player

    # 7. ТОТЕМ ПАЛАДИНА (Мощное сияние)
    else if {_cmd} is {@paladin_id}:
        apply resistance 2 to player for 1 minute
        apply absorption 5 to player for 1 minute
        apply glowing 1 to player for 20 seconds
        send "&e&l✨ &fСвет небес оберегает праведников!" to player
        play sound "block.beacon.activate" to player

    # 8. ТОТЕМ ШТОРМА (Удар молнии в обидчика)
    else if {_cmd} is {@storm_id}:
        strike lightning at player's location
        apply speed 2 to player for 40 seconds
        send "&b&l⚡ &fЭнергия бури течет в ваших жилах!" to player

    # 9. ТОТЕМ НЫРЯЛЬЩИКА
    else if {_cmd} is {@diver_id}:
        apply water breathing 1 to player for 10 minutes
        apply dolphin's grace 1 to player for 2 minutes
        apply conduit power 1 to player for 2 minutes
        send "&3&l🌊 &fОкеан признал вас своим!" to player

    # 10. ТОТЕМ ПОБЕГА (Телепорт на спавн/варп)
    else if {_cmd} is {@escape_id}:
        send "&d&l🌀 &fЭкстренная эвакуация!" to player
        execute console command "warps ambar %player%"
        play sound "entity.enderman.teleport" to player

    # 11. ТОТЕМ ФЕРМЕРА (Наполнение сытостью)
    else if {_cmd} is {@farmer_id}:
        apply saturation 5 to player for 30 seconds
        apply luck 2 to player for 5 minutes
        send "&6&l🌾 &fЗемля дает вам силы продолжать!" to player

    # 12. ТОТЕМ ЖНЕЦА (Иссушение врагов)
    else if {_cmd} is {@reaper_id}:
        loop entities in radius 10 around player:
            if loop-entity is not player:
                apply wither 3 to loop-entity for 10 seconds
        send "&8&l💀 &fСмерть прошла совсем рядом..." to player
        play sound "entity.wither.spawn" with pitch 2 to player

    # 13. ТОТЕМ ТАНКА (Огромное поглощение)
    else if {_cmd} is {@tank_id}:
        apply absorption 10 to player for 30 seconds
        apply resistance 4 to player for 15 seconds
        send "&8&l🛡 &fВы стали живой крепостью!" to player
        play sound "item.shield.block" to player

    # 14. ТОТЕМ ИНФЕРНО (Огненный взрыв)
    else if {_cmd} is {@inferno_id}:
        apply fire resistance 1 to player for 5 minutes
        loop entities in radius 5 around player:
            ignite loop-entity for 10 seconds
        send "&c&l🔥 &fПламя преисподней поглотило ваш страх!" to player

    # 15. ТОТЕМ МЕДИКА (Лечение союзников рядом)
    else if {_cmd} is {@medic_id}:
        loop players in radius 10 around player:
            apply regeneration 4 to loop-player for 10 seconds
            apply instant health 1 to loop-player
        send "&d&l💖 &fВаша жертва исцелила окружающих!" to player

    # 16. ТОТЕМ МОРОЗА (Заморозка врагов)
    else if {_cmd} is {@frost_id}:
        loop entities in radius 8 around player:
            if loop-entity is not player:
                apply slowness 5 to loop-entity for 15 seconds
        send "&b&l❄ &fСердце льда сковало ваших врагов!" to player

    # 17. ТОТЕМ УДАЧИ (Редкие эффекты)
    else if {_cmd} is {@luck_id}:
        apply luck 5 to player for 10 minutes
        apply hero of the village 1 to player for 10 minutes
        send "&2&l🍀 &fСегодня ваш счастливый день!" to player

    else if {_cmd} is {@scout_id}:
        apply speed 5 to player for 20 seconds
        loop players in radius 30 around player:
            apply glowing 1 to loop-player for 15 seconds
        send "&f&l👟 &fВы ускорились и обнаружили врагов!"

    # 19. ТОТЕМ ГРАВИТАЦИИ (Левитация врагов)
    else if {_cmd} is {@gravity_id}:
        loop entities in radius 10 around player:
            if loop-entity is not player:
                apply levitation 2 to loop-entity for 5 seconds
        send "&9&l🌌 &fГравитация сошла с ума!"

    # 20. ТОТЕМ АЛХИМИКА (Случайные баффы)
    else if {_cmd} is {@alchemist_id}:
        apply strength 1 to player for 30 seconds
        apply speed 2 to player for 30 seconds
        apply resistance 2 to player for 30 seconds
        send "&5&l🧪 &fНепредсказуемая смесь подействовала!"

    # 21. ТОТЕМ КУЗНЕЦА (Починка брони)
    else if {_cmd} is {@blacksmith_id}:
        repair player's armor
        apply resistance 3 to player for 20 seconds
        send "&6&l🔨 &fВаша броня была мгновенно восстановлена!"

    # 22. ТОТЕМ АРХАНГЕЛА (Максимальный взлет)
    else if {_cmd} is {@archangel_id}:
        apply slow falling 1 to player for 30 seconds
        push player upwards with force 2
        send "&e&l👼 &fВы вознеслись над полем боя!"

    # 23. ТОТЕМ ПУСТОТЫ (Удаление эффектов у врагов)
    else if {_cmd} is {@void_id}:
        loop players in radius 8 around player:
            clear loop-player's potion effects
        send "&0&l⬛ &fПустота поглотила магию врагов!"

    # 24. ТОТЕМ НИНДЗЯ (Дымовая завеса)
    else if {_cmd} is {@ninja_id}:
        apply speed 4 to player for 10 seconds
        apply invisibility 1 to player for 15 seconds
        play large smoke at player
        send "&8&l💨 &fИсчезновение..."

    # 25. ТОТЕМ ФЕНИКСА (Бессмертие на 5 сек)
    else if {_cmd} is {@phoenix_id}:
        apply resistance 5 to player for 6 seconds
        apply fire resistance 1 to player for 1 minute
        send "&6&l🔥 &fВы возродились из пепла!"

    # 26. ТОТЕМ ЦАРЯ МОРЕЙ (Затопление)
    else if {_cmd} is {@ocean_king_id}:
        loop entities in radius 6 around player:
            set block at loop-entity to water
        wait 3 seconds
        loop blocks in radius 6 around player:
            if loop-block is water:
                set loop-block to air

    # 27. ТОТЕМ КРУШИТЕЛЯ (Урон по области)
    else if {_cmd} is {@berserk_v2_id}:
        damage entities in radius 7 around player by 5 hearts
        send "&4&l💥 &fЗемля содрогнулась!"

    # 28. ТОТЕМ ТОРГОВЦА (Скидки/Рынок)
    else if {_cmd} is {@trader_id}:
        apply hero of the village 5 to player for 5 minutes
        send "&a&l💰 &fЛучшие предложения только для вас!"

    # 29. ТОТЕМ ПРИЗРАКА (Проход сквозь стены)
    else if {_cmd} is {@ghost_id}:
        set player's flight mode to true
        wait 10 seconds
        set player's flight mode to false
        send "&7&l👻 &fПризрачная форма активна 10 сек!"

    # 30. ТОТЕМ ДРАКОНА (Огненное дыхание)
    else if {_cmd} is {@dragon_id}:
        make player shoot dragon fireball
        send "&5&l🐲 &fГнев Дракона!"

# 31. ТОТЕМ ХАКЕРА (Остановка времени)
    else if {_cmd} is {@hacker_id}:
        # Создаем список, чтобы точно знать, кого мы заморозили
        add player to {_frozen_list::*}
        execute console command "simpleplayerfreeze:freeze %player%"
        
        # Замораживаем всех игроков вокруг и добавляем в список
        loop players in radius 10 around player:
            if loop-player is not player:
                add loop-player to {_frozen_list::*}
                execute console command "simpleplayerfreeze:freeze %loop-player%"
        
        send "&b&l💻 &fСистема взломана. Время остановлено на 8 секунд!" to player
        
        # Ждем 8 секунд
        wait 8 seconds
        
        # Размораживаем строго тех, кто попал в наш список
        loop {_frozen_list::*}:
            # ВНИМАНИЕ: Проверь, как в SPF пишется unfreeze. 
            # Если команда /unfreeze, то пишем так:
            execute console command "simpleplayerfreeze:unfreeze %loop-value%"
        
        send "&a&l🔓 &fВремя снова запущено!" to player

    # 32. ТОТЕМ ТИТАНА (Огромный рост и ХП)
    else if {_cmd} is {@titan_id}:
        apply health boost 10 to player for 3 minutes
        apply strength 3 to player for 1 minute
        send "&6&l🛡 &fВы обрели мощь ТИТАНА!"
        
# 33. ТОТЕМ БОГА (Полное бессмертие и очистка)
    else if {_cmd} is {@god_id}:
        clear player's potion effects
        apply resistance 5 to player for 15 seconds
        apply regeneration 5 to player for 10 seconds
        apply speed 3 to player for 20 seconds
        send "&e&l⭐ &fБОЖЕСТВЕННОЕ ВМЕШАТЕЛЬСТВО! Вы неуязвимы 15 секунд." to player
        play sound "ui.toast.challenge_complete" to player

    # 34. ТОТЕМ ЖАТВЫ (Кража ХП у всех вокруг)
    else if {_cmd} is {@reaper_v2_id}:
        loop players in radius 12 around player:
            if loop-player is not player:
                damage loop-player by 4 hearts
                add 2 to player's health
                play dragon breath at loop-player
        send "&4&l💀 &fВы выпили жизнь из окружающих!" to player

    # 35. ТОТЕМ АНТИ-ТРАПЕР (Проход сквозь блоки и откидывание)
    else if {_cmd} is {@anti_trap_id}:
        push entities in radius 6 around player backwards with force 3
        set player's flight mode to true
        send "&b&l🌀 &fЛовушка уничтожена! У вас 5 секунд, чтобы улететь." to player
        wait 5 seconds
        set player's flight mode to false

    # 36. ТОТЕМ МАГНАТА (Сохранение ресурсов и удача)
    else if {_cmd} is {@rich_id}:
        apply luck 10 to player for 10 minutes
        apply haste 5 to player for 3 minutes
        give player 1 netherite scrap # Маленький бонус
        send "&6&l💰 &fБогатство само идет в руки!" to player

# 37. ТОТЕМ ОВЕРЛОРДА (Призыв свиты с авто-атакой)
    else if {_cmd} is {@overlord_id}:
        # Определяем врага
        set {_enemy} to metadata value "last_attacker" of player
        
        # Спавним 3 големов через цикл
        loop 3 times:
            spawn 1 iron golem at player's location
            set {_golem} to last spawned iron golem
            
            # Ставим имя каждому
            set name of {_golem} to "&6Защитник %player%"
            
            # Натравливаем на обидчика, если он онлайн и рядом
            if {_enemy} is set:
                set target of {_golem} to {_enemy}
        
        apply strength 3 to player for 30 seconds
        send "&5&l👑 &fАрмия Оверлорда прибыла и атакует вашего обидчика!" to player
        
        # Чистим метку через 5 секунд, чтобы не было ошибок
        wait 5 seconds
        delete metadata value "last_attacker" of player
        
        
        
        
command /givetotem <text> [<player>]:
    permission: op
    trigger:
        set {_target} to arg-2 ? player
        set {_i} to totem of undying
        enchant {_i} with unbreaking 1
        
        # 1. БЕРСЕРК
        if arg-1 is "berserk":
            set name of {_i} to "§x§F§F§2§9§0§0§lТ§x§F§F§2§1§2§5§lо§x§F§F§1§9§4§A§lт§x§F§F§1§0§7§0§lе§x§F§F§0§8§9§5§lм §x§F§F§0§0§B§A§lБ§x§F§F§0§0§B§A§lе§x§F§F§0§0§B§A§lр§x§F§F§0§0§B§A§lс§x§F§F§0§0§B§A§lе§x§F§F§0§0§B§A§lр§x§F§F§0§0§B§A§lк§x§F§F§0§0§B§A§lа"
            set custom model data of {_i} to {@berserk_id}
            set lore of {_i} to "&7Ранг: &6&lЛЕГЕНДАРНЫЙ", "", "&6⚡ Способности:", " &8» &cСила II &7(60 сек.)", " &8» &eСпешка II &7(60 сек.)", "", "&4&o«Кровь закипает, разум гаснет...»"
        
        # 2. ЧЕРЕПАХА
        else if arg-1 is "turtle":
            set name of {_i} to "§x§9§1§F§F§6§2Т§x§8§B§F§1§7§Cо§x§8§5§E§3§9§6в§x§7§F§D§6§B§1и§x§7§8§C§8§C§Bч§x§7§2§B§A§E§5о§x§6§C§A§C§F§Fк §aЧерепахи"
            set custom model data of {_i} to {@turtle_id}
            set lore of {_i} to "&7Ранг: &aРедкий", "", "&2🛡 Способности:", " &8» &9Стойкость III &7(45 сек.)", " &8» &7Замедление II &7(20 сек.)", "", "&2&o«Вас не сдвинуть, как вековую скалу.»"

        # 3. ФАНТОМ
        else if arg-1 is "phantom":
            set name of {_i} to "&f&lТотем &fФантома"
            set custom model data of {_i} to {@phantom_id}
            set lore of {_i} to "&7Ранг: &fМистический", "", "&f👻 Способности:", " &8» &7Невидимость &7(30 сек.)", " &8» &bСкорость III &7(30 сек.)", " &8» &fПрыгучесть III &7(30 сек.)", "", "&7&o«Вы — лишь эхо в ночном тумане.»"

        # 4. ВАМПИР
        else if arg-1 is "vampire":
            set name of {_i} to "&4&lТотем &cВампира"
            set custom model data of {_i} to {@vampire_id}
            set lore of {_i} to "&7Ранг: &cДревний", "", "&4🩸 Способности:", " &8» &dДоп. ХП &7(2 мин.)", " &8» &cРегенерация III &7(15 сек.)", "", "&c&o«Твоя жизнь — моя жатва.»"

        # 5. ШАХТЕР
        else if arg-1 is "miner":
            set name of {_i} to "&e&lТотем &6Шахтера"
            set custom model data of {_i} to {@miner_id}
            set lore of {_i} to "&7Ранг: &eОбычный", "", "&6⚒ Способности:", " &8» &eСпешка III &7(5 мин.)", " &8» &bНочное зрение &7(5 мин.)", "", "&8&o«Глубины мира подчиняются упорным.»"

        # 6. ВОР
        else if arg-1 is "thief":
            set name of {_i} to "&7&lТотем &8Вора"
            set custom model data of {_i} to {@thief_id}
            set lore of {_i} to "&7Ранг: &8Теневой", "", "&8👤 Способности:", " &8» &8Слепота врагам &7(7б.)", " &8» &fСкорость IV &7(10 сек.)", "", "&7&o«Ушел раньше, чем тебя заметили.»"

        # 7. ПАЛАДИН
        else if arg-1 is "paladin":
            set name of {_i} to "&e&lТотем &6Паладина"
            set custom model data of {_i} to {@paladin_id}
            set lore of {_i} to "&7Ранг: &6Святой", "", "&e✨ Способности:", " &8» &9Стойкость II &7(1 мин.)", " &8» &eПоглощение V &7(1 мин.)", "", "&6&o«Свет не даст тебе погаснуть.»"

        # 8. ШТОРМ
        else if arg-1 is "storm":
            set name of {_i} to "&b&lТотем &3Шторма"
            set custom model data of {_i} to {@storm_id}
            set lore of {_i} to "&7Ранг: &bСтихийный", "", "&b⚡ Способности:", " &8» &fУдар молнии в обидчика", " &8» &bСкорость II &7(40 сек.)", "", "&3&o«Небеса плачут молниями.»"

        # 9. НЫРЯЛЬЩИК
        else if arg-1 is "diver":
            set name of {_i} to "&3&lТотем &bНыряльщика"
            set custom model data of {_i} to {@diver_id}
            set lore of {_i} to "&7Ранг: &3Водный", "", "&3🌊 Способности:", " &8» &bДыхание &7(10 мин.)", " &8» &3Грация дельфина &7(2 мин.)", "", "&1&o«Бездна стала твоим домом.»"

        # 10. ПОБЕГ
        else if arg-1 is "escape":
            set name of {_i} to "&d&lТотем &5Побега"
            set custom model data of {_i} to {@escape_id}
            set lore of {_i} to "&7Ранг: &dМагический", "", "&d🌀 Способности:", " &8» &dТелепортация на базу", " &8» &fЭкстренный разрыв пространства", "", "&5&o«Сегодня не день для твоей смерти.»"

        # 11. ФЕРМЕР
        else if arg-1 is "farmer":
            set name of {_i} to "&6&lТотем &eФермера"
            set custom model data of {_i} to {@farmer_id}
            set lore of {_i} to "&7Ранг: &eТрудовой", "", "&e🌾 Способности:", " &8» &6Насыщение V &7(30 сек.)", " &8» &2Удача II &7(5 мин.)", "", "&2&o«Земля щедра к своим детям.»"

        # 12. ЖНЕЦ
        else if arg-1 is "reaper":
            set name of {_i} to "&8&lТотем &4Жнеца"
            set custom model data of {_i} to {@reaper_id}
            set lore of {_i} to "&7Ранг: &4Проклятый", "", "&8💀 Способности:", " &8» &8Иссушение III &7(R: 10б.)", " &8» &4Тьма вокруг", "", "&4&o«Время жатвы пришло.»"

        # 13. ТАНК
        else if arg-1 is "tank":
            set name of {_i} to "&8&lТотем &7Танка"
            set custom model data of {_i} to {@tank_id}
            set lore of {_i} to "&7Ранг: &8Тяжелый", "", "&8🛡 Способности:", " &8» &eПоглощение X &7(30 сек.)", " &8» &9Стойкость IV &7(15 сек.)", "", "&8&o«Несокрушимый оплот.»"

