        # 35. АНТИ-ТРАПЕР
        else if arg-1 is "anti_trap":
            set name of {_i} to "&b&l🌀 ТОТЕМ АНТИ-ТРАПЕРА"
            set custom model data of {_i} to {@anti_trap_id}
            set lore of {_i} to "&7Ранг: &bЛЕГЕНДАРНЫЙ", "", "&b✨ Способности:", " &8» &fРаскидывает врагов в радиусе 6б.", " &8» &fДает полет на 5 секунд", "", "&3&o«Стены вас не удержат.»"

        # 36. МАГНАТ
        else if arg-1 is "rich":
            set name of {_i} to "&6&l💰 ТОТЕМ МАГНАТА"
            set custom model data of {_i} to {@rich_id}
            set lore of {_i} to "&7Ранг: &6БОГАТЫЙ", "", "&e💎 Способности:", " &8» &fУдача X на 10 минут", " &8» &fСпешка V", "", "&6&o«Деньги решают всё.»"

        # 37. ОВЕРЛОРД
        else if arg-1 is "overlord":
            set name of {_i} to "&5&l👑 ТОТЕМ ОВЕРЛОРДА"
            set custom model data of {_i} to {@overlord_id}
            set lore of {_i} to "&7Ранг: &5ПОВЕЛИТЕЛЬ", "", "&d⚔ Способности:", " &8» &fПризывает 3 железных големa", " &8» &fСила III на 30 секунд", "", "&5&o«Склонитесь перед королем!»"



        give {_i} to {_target}
        send "&a&l✔ &fВы выдали тотем &e%arg-1% &fигроку &b%{_target}%" to player



on tab complete of "/givetotem":
    set {_t::*} to "berserk", "turtle", "phantom", "vampire", "miner", "thief", "paladin", "storm", "diver", "escape", "farmer", "reaper", "tank", "inferno", "medic", "frost", "luck", "scout", "gravity", "alchemist", "blacksmith", "archangel", "void", "ninja", "phoenix", "ocean_king", "berserk_v2", "trader", "ghost", "dragon", "hacker", "titan", "god", "reaper_v2", "anti_trap", "rich" and "overlord"
    
    # Очищаем стандартные подсказки (ники игроков и т.д.)
    clear tab completions
    
    # Если мы пишем ПЕРВЫЙ аргумент (название тотема)
    if tab arg 2 is not set:
        if tab arg 1 is not set:
            add {_t::*} to tab completions
        else:
            loop {_t::*}:
                if loop-value starts with tab arg 1:
                    add loop-value to tab completions
    
    # Если мы выбрали тотем и пишем ВТОРОЙ аргумент (ник игрока)
    else if tab arg 3 is not set:
        loop all players:
            if tab arg 2 is not set:
                add all players to tab completions
            else:
                if loop-player's name starts with tab arg 2:
                    add loop-player's name to tab completions



command /buytotem <text>:
    trigger:
        # 1. Проверка прав
        if player does not have permission "dzuni.skript":
            send "&c&l❕ &fЭтот ранг доступен только элите! У вас нет прав."
            play sound "block.iron_door.close" to player
            stop

        # 2. Настройка цен и названий для анонса
        set {_price} to 0
        if arg-1 is "god":
            set {_price} to 125000
            set {_msg} to "&e&l⭐ ТОТЕМ БОГА ⭐"
        else if arg-1 is "reaper_v2":
            set {_price} to 100000
            set {_msg} to "&4&l💀 ТОТЕМ ВЕЛИКОЙ ЖАТВЫ"
        else if arg-1 is "anti_trap":
            set {_price} to 90000
            set {_msg} to "&b&l🌀 ТОТЕМ АНТИ-ТРАПЕРА"
        else if arg-1 is "rich":
            set {_price} to 75000
            set {_msg} to "&6&l💰 ТОТЕМ МАГНАТА"
        else if arg-1 is "overlord":
            set {_price} to 110000
            set {_msg} to "&5&l👑 ТОТЕМ ОВЕРЛОРДА"
        
        if {_price} is 0:
            send "&cОшибка: Цена не установлена."
            stop

        # 3. Проверка баланса
        set {_bal} to player's balance
        
        if {_bal} >= {_price}:
            # Снимаем деньги
            remove {_price} from player's balance
            
            # Вызываем твою команду выдачи
            execute console command "givetotem %arg-1% %player%"
            
            # Сообщение самому игроку
            send "&a&l✔ &fВы успешно купили тотем за &e%{_price}%¥"
            play sound "entity.player.levelup" with volume 0.5 to player
            show flash at player

            # --- ОБЩЕЕ ОБЪЯВЛЕНИЕ (БЕЗ НИКА) ---
            broadcast ""
            broadcast "  &d&l✨ &fКто-то приобрёл %{_msg}% &d&l✨"
            broadcast "  &7&oСчастливчик стал ещё сильнее..."
            broadcast ""
            
        else:
            set {_need} to {_price} - {_bal}
            send "&c&l❕ &fНедостаточно средств! Вам не хватает &a¥%{_need}%"
            send "&7&o(Ваш текущий баланс: %{_bal}%)"
            play sound "block.note_block.bass" to player








# --- КОМАНДА ДЛЯ ОТКРЫТИЯ МЕНЮ ОБМЕНА ---
command /totemtrade:
    trigger:
        # Используем переменную для надежного сравнения заголовка
        set {_t} to "§0Обмен: 2 к 1"
        set {_gui} to chest inventory with 6 rows named {_t}
        
        # Заполнитель фона
        loop 54 times:
            set slot (loop-number - 1) of {_gui} to black stained glass pane named " "
        
        # Информационные панели
        set slot 10 of {_gui} to barrier named "&c&lСлот 1" with lore "&7Нажмите на кастомный тотем", "&7в инвентаре, чтобы положить его сюда."
        set slot 19 of {_gui} to barrier named "&c&lСлот 2" with lore "&7Нажмите на кастомный тотем", "&7в инвентаре, чтобы положить его сюда."
        set slot 13 of {_gui} to sunflower named "&e&lИНСТРУКЦИЯ" with lore "&7Положите 2 любых кастомных", "&7тотема слева, чтобы выбрать", "&7любой обычный тотем справа.", "", "&c⚠ Эпические тотемы недоступны!"
        set slot 46 of {_gui} to red wool named "&c&lСбросить обмен"
        set {_back} to paper named "&a&lНазад" with lore "&7Нажмите, чтобы вернуться", "&7в главное меню тотемов."
        set custom model data of {_back} to 10179
        set slot 48 of {_gui} to {_back}
        
        
        # Отображаем тотемы из памяти
        if {trade::%player%::1} is set:
            set slot 10 of {_gui} to {trade::%player%::1}
        if {trade::%player%::2} is set:
            set slot 19 of {_gui} to {trade::%player%::2}

        # Список тотемов на русском
        set {_names::*} to "БЕРСЕРКА", "ЧЕРЕПАХИ", "ФАНТОМА", "ВАМПИРА", "ШАХТЕРА", "ВОРА", "ПАЛАДИНА", "ШТОРМА", "НЫРЯЛЬЩИКА", "ПОБЕГА", "ФЕРМЕРА", "ЖНЕЦА", "ТАНКА", "ИНФЕРНО", "МЕДИКА", "МОРОЗА", "УДАЧИ", "СКАУТА", "ГРАВИТАЦИИ", "АЛХИМИКА", "КУЗНЕЦА", "АРХАНГЕЛА", "ПУСТОТЫ", "НИНДЗЯ", "ФЕНИКСА", "ЦАРЯ МОРЕЙ", "КРУШИТЕЛЯ", "ТОРГОВЦА", "ПРИЗРАКА", "ДРАКОНА", "ХАКЕРА", "ТИТАНА"
        # Соответствующие им ID для консоли
        set {_ids::*} to "berserk", "turtle", "phantom", "vampire", "miner", "thief", "paladin", "storm", "diver", "escape", "farmer", "reaper", "tank", "inferno", "medic", "frost", "luck", "scout", "gravity", "alchemist", "blacksmith", "archangel", "void", "ninja", "phoenix", "ocean_king", "berserk_v2", "trader", "ghost", "dragon", "hacker", "titan"
        
        set {_s} to 14
        loop {_names::*}:
            set {_item} to totem of undying
            enchant {_item} with unbreaking 1
            add hide enchants to item flags of {_item}
            
            # Сохраняем ID в скрытом лоре
            set {_id} to {_ids::%loop-index%}
            set slot {_s} of {_gui} to {_item} named "&6&l💰 ТОТЕМ %loop-value%" with lore "&8ID: %{_id}%", "&7Нажмите, чтобы получить этот тотем"
            
            add 1 to {_s}
            if {_s} is 18 or 27 or 36 or 45:
                add 5 to {_s}

        open {_gui} to player

# --- ОБРАБОТКА КЛИКОВ ---
on inventory click:
    if name of event-inventory contains "Обмен: 2 к 1":
        cancel event
        
        # Защита от клика по пустоте
        set {_item} to event-item
        if {_item} is air:
            stop

        # 1. Клик в инвентаре игрока
        if clicked inventory is player's inventory:
            set {_cmd} to custom model data of {_item}
            if {_cmd} is set:
                if {_cmd} >= 1001 and {_cmd} <= 1032:
                    if {trade::%player%::1} is not set:
                        set {trade::%player%::1} to {_item}
                        remove 1 of {_item} from player's inventory
                    else if {trade::%player%::2} is not set:
                        set {trade::%player%::2} to {_item}
                        remove 1 of {_item} from player's inventory
                    else:
                        send "&c[!] Все слоты заняты."
                    execute player command "totemtrade"
                else:
                    send "&c[!] Этот тотем слишком мощный для обмена!"
            stop

        # 2. Клик в GUI
        set {_slot} to index of clicked slot
        
        # Кнопка сброса
        if {_slot} is 46:
            loop 2 times:
                if {trade::%player%::%loop-number%} is set:
                    give {trade::%player%::%loop-number%} to player
            delete {trade::%player%::*}
            execute player command "totemtrade"
            stop
        # Кнопка Назад (слот 48)
        if {_slot} is 48:
            close player's inventory
            execute console command "dm open totems %player%"
            play sound "UI.BUTTON.CLICK" with volume 1 and pitch 1 to player
            stop    
        # Поиск ID в лоре нажатого предмета
        set {_lore::*} to lore of {_item}
        loop {_lore::*}:
            if loop-value contains "ID: ":
                if {trade::%player%::1} is set:
                    if {trade::%player%::2} is set:
                        # Извлекаем ID
                        set {_id} to loop-value
                        replace "&8ID: " with "" in {_id}
                        
                        # Выдача
                        delete {trade::%player%::*}
                        close player's inventory
                        execute console command "givetotem %{_id}% %player%"
                        send "&a&l✔ &fОбмен завершен! Вы получили новый тотем."
                        play sound "entity.player.levelup" to player
                    else:
                        send "&c[!] Положите 2 тотема для обмена!"
                else:
                    send "&c[!] Положите 2 тотема для обмена!"
                stop