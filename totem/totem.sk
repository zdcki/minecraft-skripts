            set custom model data of {_i} to {@dragon_id}
            set lore of {_i} to "&7Ранг: &5Древний", "", "&5🐲 Способности:", " &8» &dЗалп Драконьего огня", " &8» &5Величие Края", "", "&d&o«Твой голос — это гром, твое дыхание — огонь.»"

