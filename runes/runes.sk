function setupRuneStoreItem(gui: inventory, slot: integer, model: integer, price: integer, data: text):
    set {_d::*} to {_data} split at "|"
    set {_name} to {_d::1}
    delete {_d::1}
    
    set {_item} to paper named "%{_name}%"
    set lore of {_item} to {_d::*}
    add "" to lore of {_item}
    add "&fЦена: &e%{_price}% &6монет" to lore of {_item}
    add "&8&oДолжна лежать в инвентаре" to lore of {_item}
    add "" to lore of {_item}
    add "&6▶ Нажмите для покупки" to lore of {_item}
    # Скрытая техническая строка для скрипта (последняя)
    add "&0ID:%{_model}%|PRICE:%{_price}%" to lore of {_item}
    
    set custom model data of {_item} to {_model}
    set slot {_slot} of {_gui} to {_item}

on inventory click:
    if name of event-inventory is "&8➲ Древние Руны: Магазин":
        cancel event
        set {_item} to event-item
        if {_item} is air:
            stop
        if index of event-slot is 26:
            send "123" to player
            close player's inventory
            execute player command "/guiderune"
            stop

        # Если это фоновое стекло
        if custom model data of {_item} is 0:
            stop

        # Обработка книги (слот 26)


        # --- ЛОГИКА ПОКУПКИ ---
        set {_lore::*} to lore of {_item}
        set {_tech_line} to last element of {_lore::*}
        
        # Проверяем, что это товар
        if {_tech_line} contains "PRICE:":
            set {_p_split::*} to {_tech_line} split at "PRICE:"
            set {_price} to {_p_split::2} parsed as number
            
            # --- ОЧИСТКА БАЛАНСА (КАК В ТВОЕМ ПРИМЕРЕ) ---
            set {_raw_bal} to "%player's balance%"
            replace all "," and "¥" and "$" and " " with "" in {_raw_bal}
            set {_split_bal::*} to {_raw_bal} split at "."
            set {_final_bal} to {_split_bal::1} parsed as number
            
            # Сравнение уже чистых чисел
            if {_final_bal} >= {_price}:
                if player has enough space for 1 of {_item}:
                    remove {_price} from player's balance
                    
                    # Создаем чистую руну для выдачи
                    set {_r} to {_item}
                    set {_clean_lore::*} to lore of {_r}
                    
                    # Удаляем магазинные строки
                    loop 5 times:
                        delete {_clean_lore::%size of {_clean_lore::*}%}
                    
                    add "&8&oДолжна лежать в инвентаре" to {_clean_lore::*}
                    add "&8ID: %custom model data of {_item}%" to {_clean_lore::*}
                    set lore of {_r} to {_clean_lore::*}
                    
                    give {_r} to player
                    send action bar "&a&l✔ &fКуплено за &e%{_price}% ¥" to player
                    play sound "entity.player.levelup" with volume 0.5 and pitch 2 at player
                    play sound "block.amethyst_block.break" with volume 1 and pitch 1 at player
                else:
                    send action bar "&c&l✕ &fНет места в инвентаре!" to player
            else:
                # Если денег не хватило
                send action bar "&c&l✕ &fНедостаточно средств! &7(Нужно: &a¥%{_price}%&7)" to player
                play sound "block.note_block.bass" at player